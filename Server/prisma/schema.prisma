generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = "mysql://root:@localhost:3306/db_kantin_sekolah"
}

enum Role {
  siswa
  penjual
  admin
}

enum StatusOrder {
  pending
  dimasak
  siap
  selesai
}

model User {
  id        Int      @id @default(autoincrement())
  nama      String
  nisn      String?  @unique  // hanya siswa
  username  String?  @unique  // hanya penjual/admin
  password  String
  role      Role     @default(siswa)
  foto      String?  @default("blank-profile-picture-973460.png")
  createdAt DateTime @default(now())

  orders    Order[]
  kantin    Kantin?  // relasi ke kantin kalau role = penjual
}

model Kantin {
  id        Int       @id @default(autoincrement())
  nama      String
  userId    Int       @unique  // 1 penjual = 1 kantin
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])
  products  Product[]
}

model Product {
  id        Int      @id @default(autoincrement())
  nama      String
  harga     Decimal
  stok      Int
  gambar    String?
  kantinId  Int
  createdAt DateTime @default(now())

  kantin    Kantin    @relation(fields: [kantinId], references: [id])
  orderItems OrderItem[]
}

model Order {
  id        Int         @id @default(autoincrement())
  status    StatusOrder @default(pending)
  total     Decimal
  userId    Int
  createdAt DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  produkId  Int
  quantity  Int
  harga     Decimal // snapshot harga saat order

  order     Order   @relation(fields: [orderId], references: [id])
  produk    Product @relation(fields: [produkId], references: [id])
}

